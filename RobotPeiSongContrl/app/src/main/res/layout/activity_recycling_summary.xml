<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <!-- 1. 回收任务信息文本框（滚动展示，不可编辑） -->
    <TextView
        android:id="@+id/tv_recycle_records"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/shape_edittext_border"
        android:padding="15dp"
        android:gravity="top|left"
        android:scrollbars="vertical"
        android:textColor="@android:color/black"
        android:text="暂无执行过的回收任务"
        android:layout_marginBottom="20dp"/>

    <!-- 2. 开门/关门互斥按钮（单个按钮，重合显示，替换原有两个按钮） -->
    <Button
        android:id="@+id/btn_door_switch"
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:text="一键开门"
        android:background="@drawable/button_sky_blue_rect"
        android:textColor="@android:color/white"
        android:layout_marginBottom="15dp"/>

    <!-- 3. 回桩按钮（独立展示，突出重要性，原有逻辑不变） -->
    <Button
        android:id="@+id/btn_return_to_charging"
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:text="回桩"
        android:background="@drawable/button_sea_blue_rect"
        android:textColor="@android:color/white"
        android:textSize="18sp"/>

</LinearLayout>