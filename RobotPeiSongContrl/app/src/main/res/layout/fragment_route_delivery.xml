<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 新建方案按钮 -->
        <Button
            android:id="@+id/btn_create_plan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="新建路线方案"
            android:background="@drawable/button_sky_blue_rect"
            android:textColor="@android:color/white"
            android:textSize="18sp"/>

        <!-- 路线方案选择 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择路线方案"
            android:textSize="18sp"
            android:textColor="@android:color/black"/>

        <Spinner
            android:id="@+id/spinner_plans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_white_rect"
            android:padding="8dp"/>

        <!-- 方案详情展示 -->
        <TextView
            android:id="@+id/tv_plan_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请选择或新建路线方案"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:background="@drawable/edittext_white_rect"
            android:padding="12dp"
            android:minHeight="100dp"/>

        <!-- 配送时间选择 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择配送时间"
            android:textSize="18sp"
            android:textColor="@android:color/black"/>

        <TimePicker
            android:id="@+id/time_picker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:numbersBackgroundColor="@color/skyblue"
            android:numbersTextColor="@android:color/white"
            android:numbersSelectorColor="@color/seablue"/>

        <!-- 确认创建定时任务按钮 -->
        <Button
            android:id="@+id/btn_confirm_task"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:text="确认创建定时任务"
            android:background="@drawable/button_sea_blue_rect"
            android:textColor="@android:color/white"
            android:textSize="18sp"/>

    </LinearLayout>
</ScrollView>